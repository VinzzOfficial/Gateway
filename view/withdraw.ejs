<%- include('partials/header', { title: 'Withdraw' }) %>

<div class="mb-4 flex flex-col md:flex-row md:items-end justify-between gap-4 font-medium">
  <div>
    <h1 class="text-xl font-medium text-gray-900 tracking-tight">Withdraw Saldo</h1>
    <p class="text-xs font-medium text-gray-900 mt-1">Cairkan saldo Anda ke rekening atau e-wallet pilihan.</p>
  </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      showToast('<%= error %>', 'error');
    });
  </script>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      showToast('<%= success %>', 'success');
    });
  </script>
<% } %>

<% if (!user.ewallet || !user.accountNumber || !user.accountName) { %>
  <div class="card-custom p-6 mb-8 text-center sm:text-left flex flex-col sm:flex-row items-center gap-6 font-medium">
    <div class="w-16 h-16 rounded-full bg-gray-900 text-white flex items-center justify-center shrink-0">
      <i class="fas fa-id-card text-xl"></i>
    </div>
    <div class="flex-1">
      <h2 class="text-xl font-medium text-gray-900 mb-1">Lengkapi Data Pencairan</h2>
      <p class="text-xs font-medium text-gray-900 mb-4 sm:mb-0">Anda harus mengatur detail rekening atau e-wallet di halaman profil terlebih dahulu sebelum dapat melakukan penarikan saldo.</p>
    </div>
    <a href="/profile" class="btn-dark-custom bg-gray-900 text-white hover:bg-gray-800 px-6 py-2.5 text-xs font-medium whitespace-nowrap inline-flex items-center justify-center gap-2 rounded-lg transition-all">
      <i class="fas fa-user-edit text-xs"></i> Ke Profil
    </a>
  </div>
<% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 font-medium">
    
    <div class="card-custom p-6 md:col-span-1 flex flex-col justify-center">
      <h2 class="text-sm font-medium text-gray-900">Saldo Tersedia :</h2>
      <div class="text-xl font-medium text-gray-900 mb-5">Rp <%= user.balance.toLocaleString() %></div>
      
      <div class="bg-gray-100 rounded-lg p-3 border border-gray-200 text-xs font-medium">
        <div class="flex flex-col gap-1.5">
          <div class="flex justify-between items-center text-gray-900 font-medium">
            <span>Metode</span> 
            <span class="font-medium text-gray-900"><%= user.ewallet %></span>
          </div>
          <div class="flex justify-between items-center text-gray-900 font-medium">
            <span>No. Rek/Akun</span> 
            <span class="font-medium text-gray-900"><%= user.accountNumber %></span>
          </div>
          <div class="flex justify-between items-center text-gray-900 font-medium">
            <span>Atas Nama</span> 
            <span class="font-medium text-gray-900"><%= user.accountName %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="card-custom p-6 md:col-span-2">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-8 rounded-lg bg-gray-900 text-white flex items-center justify-center font-medium">
          <i class="fas fa-money-bill-transfer text-xs"></i>
        </div>
        <h2 class="text-xl font-medium text-gray-900">Ajukan Penarikan Baru</h2>
      </div>
      
      <form method="POST" action="/withdraw/request" class="space-y-4 font-medium" onsubmit="this.querySelector('button[type=submit]').disabled = true;">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1.5">Nominal Penarikan (Min. Rp <%= settings.minWithdraw.toLocaleString() %>)<p class="text-gray-700">Proses Penarikan 1 x 24 Jam</p></label>
          <input name="amount" type="number" placeholder="Contoh: 50000" class="form-control-custom text-xs font-medium text-gray-700" min="<%= settings.minWithdraw %>" required>
        </div>
        
        <div class="flex items-center justify-between bg-gray-100 text-gray-700 p-3 rounded-lg border border-gray-200 text-xs font-medium">
          <span class="flex items-center gap-2"><i class="fas fa-info-circle text-gray-900 text-xs"></i> Biaya Admin (Fee)</span>
          <span class="font-medium text-gray-900">Rp <%= settings.feeWithdraw.toLocaleString() %></span>
        </div>

        <button type="submit" class="btn-dark-custom bg-gray-900 text-white hover:bg-gray-800 w-full py-3 text-xs font-medium flex items-center justify-center gap-2 mt-2 rounded-lg transition-all">
          <i class="fas fa-paper-plane text-xs"></i> Proses Penarikan
        </button>
      </form>
    </div>

  </div>
<% } %>

<div class="mb-4 flex items-center gap-3 font-medium">
  <div class="w-8 h-8 rounded-lg bg-gray-900 text-white flex items-center justify-center font-medium">
    <i class="fas fa-history text-xs"></i>
  </div>
  <h2 class="text-xl font-medium text-gray-900">Riwayat Withdraw</h2>
</div>

<div class="card-custom overflow-hidden mb-8 font-medium">
  <div class="overflow-x-auto overflow-y-auto max-h-[400px]">
    <table class="w-full text-xs text-left whitespace-nowrap font-medium">
      <thead class="bg-gray-100 text-xs text-gray-900 font-medium border-b border-gray-200 sticky top-0 z-10 shadow-sm">
        <tr>
          <th class="px-6 py-4 font-medium">Jumlah</th>
          <th class="px-6 py-4 font-medium">Biaya (Fee)</th>
          <th class="px-6 py-4 font-medium">Metode</th>
          <th class="px-6 py-4 font-medium">No Rekening</th>
          <th class="px-6 py-4 font-medium">Status</th>
          <th class="px-6 py-4 font-medium">Keterangan</th>
          <th class="px-6 py-4 font-medium">Tanggal</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 font-medium">
        <% if (withdrawals.length === 0) { %>
          <tr>
            <td colspan="7" class="px-6 py-8 text-center font-medium text-gray-900 text-xs">Belum ada riwayat penarikan.</td>
          </tr>
        <% } else { %>
          <% withdrawals.forEach(w => { %>
          <tr class="hover:bg-gray-100 transition-colors">
            <td class="px-6 py-4 font-medium text-gray-900 text-xs">Rp <%= w.amount.toLocaleString() %></td>
            <td class="px-6 py-4 font-medium text-gray-900 text-xs">Rp <%= w.fee ? w.fee.toLocaleString() : '0' %></td>
            <td class="px-6 py-4 font-medium text-gray-700 text-xs"><%= w.method %></td>
            <td class="px-6 py-4 text-xs">
              <div class="font-medium text-gray-900"><%= w.accountNumber || '-' %></div>
              <div class="text-[10px] text-gray-900 mt-0.5">a.n <%= w.accountName || '-' %></div>
            </td>
            <td class="px-6 py-4 text-xs">
              <span class="status-badge font-medium <%= w.status==='success'?'status-success':w.status==='rejected'?'status-error':'status-pending' %>">
                <% if(w.status==='success'){ %><i class="fas fa-check-circle"></i><% } %>
                <% if(w.status==='pending'){ %><i class="fas fa-clock"></i><% } %>
                <% if(w.status==='rejected'){ %><i class="fas fa-times-circle"></i><% } %>
                <%= w.status.toUpperCase() %>
              </span>
            </td>
            <td class="px-6 py-4 text-xs font-medium text-gray-900 whitespace-normal min-w-[200px]">
              <%= w.adminNote || '-' %>
            </td>
            <td class="px-6 py-4 text-xs font-medium text-gray-900"><%= w.createdAt.toLocaleString() %></td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>
