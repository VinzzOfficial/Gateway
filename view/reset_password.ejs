<%- include('partials/header', { title: 'Buat Password Baru' }) %>

<div class="flex flex-col items-center justify-center min-h-[75vh] font-medium">
  
  <div class="card-custom p-8 w-full max-w-md relative overflow-hidden font-medium">
    <!-- Garis Aksen -->
    <div class="absolute top-0 left-0 w-full h-1.5 bg-gray-900"></div>

    <!-- Header Reset Password -->
    <div class="text-center mb-8 mt-2 font-medium">
      <% if (settings.logoUrl) { %>
        <img src="<%= settings.logoUrl %>" alt="Logo" class="w-12 h-12 rounded-xl object-cover mx-auto mb-4 shadow-sm" />
      <% } else { %>
        <div class="w-12 h-12 rounded-xl bg-gray-900 text-white flex items-center justify-center text-xl mx-auto mb-4 font-medium shadow-sm">
          <i class="fa-solid fa-lock text-xl"></i>
        </div>
      <% } %>
      <h2 class="text-xl font-medium text-gray-900">Buat Password Baru</h2>
      <p class="text-xs font-medium text-gray-900 mt-1">Silakan masukkan password baru untuk akun Anda</p>
    </div>

    <!-- Alert Error (Warna disamakan dengan login) -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 border border-red-400 text-red-800 px-4 py-3 rounded-lg mb-6 text-xs font-medium flex items-center gap-2">
        <i class="fas fa-exclamation-circle text-xl"></i> <%= error %>
      </div>
    <% } %>

    <!-- Form Reset Password -->
    <form method="POST" action="/reset-password/<%= typeof token !== 'undefined' ? token : '' %>" class="space-y-5 font-medium">
      
      <!-- Input Password Baru -->
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1.5">Password Baru</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
            <i class="fas fa-lock text-xs"></i>
          </div>
          <input id="passwordInput1" name="password" type="password" placeholder="••••••••" 
                 class="form-control-custom pl-10 pr-10 text-xs font-medium text-gray-700" required>
          
          <div class="absolute inset-y-0 right-0 pr-3.5 flex items-center cursor-pointer text-gray-400 hover:text-gray-900 transition-colors" onclick="togglePassword('passwordInput1', 'toggleIcon1')">
            <i id="toggleIcon1" class="far fa-eye text-xs"></i>
          </div>
        </div>
      </div>
      
      <!-- Input Konfirmasi Password Baru -->
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1.5">Konfirmasi Password</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
            <i class="fas fa-lock text-xs"></i>
          </div>
          <input id="passwordInput2" name="confirmPassword" type="password" placeholder="••••••••" 
                 class="form-control-custom pl-10 pr-10 text-xs font-medium text-gray-700" required>
          
          <div class="absolute inset-y-0 right-0 pr-3.5 flex items-center cursor-pointer text-gray-400 hover:text-gray-900 transition-colors" onclick="togglePassword('passwordInput2', 'toggleIcon2')">
            <i id="toggleIcon2" class="far fa-eye text-xs"></i>
          </div>
        </div>
      </div>

      <div class="pt-2">
        <button class="btn-dark-custom bg-gray-900 text-white hover:bg-gray-800 w-full py-3 text-xs font-medium flex items-center justify-center gap-2 rounded-lg transition-all">
          Simpan Password Baru <i class="fas fa-arrow-right text-xs"></i>
        </button>
      </div>
    </form>

  </div>

</div>

<!-- Script untuk Toggle Password -->
<script>
  function togglePassword(inputId, iconId) {
    const passwordInput = document.getElementById(inputId);
    const toggleIcon = document.getElementById(iconId);
    
    if (passwordInput.type === 'password') {
      passwordInput.type = 'text';
      toggleIcon.classList.remove('fa-eye');
      toggleIcon.classList.add('fa-eye-slash');
    } else {
      passwordInput.type = 'password';
      toggleIcon.classList.remove('fa-eye-slash');
      toggleIcon.classList.add('fa-eye');
    }
  }
</script>

<%- include('partials/footer') %>