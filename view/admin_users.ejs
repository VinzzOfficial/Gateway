<%- include('partials/header', { title: 'Kelola User' }) %>

<!-- Page Header -->
<div class="mb-4 flex flex-col md:flex-row md:items-end justify-between gap-4 font-medium">
  <div>
    <h1 class="text-xl font-medium text-gray-900">Daftar Pengguna</h1>
    <p class="text-xs font-medium text-gray-900 mt-1">Pantau dan kelola data akun serta saldo seluruh pengguna terdaftar.</p>
  </div>
</div>

<!-- Search Form -->
<form class="mb-8 flex flex-col sm:flex-row gap-3 font-medium" method="GET">
  <div class="relative flex-1 max-w-md">
    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
      <i class="fas fa-search text-xs"></i>
    </div>
    <input name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Cari username atau email pengguna..." class="form-control-custom pl-10 w-full py-2.5 text-xs font-medium text-gray-700">
  </div>
  <button type="submit" class="btn-dark-custom bg-gray-900 text-white hover:bg-gray-800 px-6 py-2.5 text-xs font-medium flex items-center justify-center gap-2 whitespace-nowrap rounded-lg transition-all">
    Cari Pengguna
  </button>
</form>

<!-- Table Container -->
<div class="card-custom overflow-hidden mb-8 font-medium">
  <div class="overflow-x-auto">
    <table class="w-full text-xs text-left whitespace-nowrap font-medium">
      <thead class="bg-gray-100 text-xs text-gray-900 font-medium border-b border-gray-200">
        <tr>
          <th class="px-6 py-4 font-medium">Informasi Pengguna</th>
          <th class="px-6 py-4 font-medium">Saldo Saat Ini</th>
          <th class="px-6 py-4 font-medium">Tanggal Daftar</th>
          <th class="px-6 py-4 text-center font-medium">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 font-medium">
        <% if (users.length === 0) { %>
          <tr>
            <td colspan="4" class="px-6 py-8 text-center font-medium text-gray-900 text-xs">Belum ada pengguna terdaftar.</td>
          </tr>
        <% } else { %>
          <% users.forEach(u => { %>
          <tr class="hover:bg-gray-100 transition-colors">
            <td class="px-6 py-4 text-xs">
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-medium text-gray-900"><%= u.username %></span>
                <span class="text-xs font-medium text-gray-900"><%= u.email %></span>
              </div>
            </td>
            <td class="px-6 py-4 text-xs font-medium text-gray-900">
              Rp <%= u.balance.toLocaleString() %>
            </td>
            <td class="px-6 py-4 text-xs font-medium text-gray-900">
              <%= u.createdAt.toLocaleString() %>
            </td>
            <td class="px-6 py-4 text-center text-xs">
              <a href="/admin/users/<%= u._id %>/edit" class="inline-flex items-center justify-center gap-1.5 bg-gray-900 hover:bg-gray-800 text-white px-3 py-1.5 rounded-md text-xs font-medium transition-colors shadow-sm">
                <i class="fas fa-user-edit text-xs"></i> Edit
              </a>
            </td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>