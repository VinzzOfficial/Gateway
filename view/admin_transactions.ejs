<%- include('partials/header', { title: 'Semua Transaksi' }) %>

<!-- Page Header -->
<div class="mb-4 flex flex-col md:flex-row md:items-end justify-between gap-4 font-medium">
  <div>
    <h1 class="text-xl font-medium text-gray-900">Semua Transaksi</h1>
    <p class="text-xs font-medium text-gray-900 mt-1">Pantau seluruh transaksi deposit dan withdraw pengguna.</p>
  </div>
</div>

<!-- Search Form -->
<form class="mb-8 flex flex-col sm:flex-row gap-3 font-medium">
  <div class="relative flex-1 max-w-md">
    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
      <i class="fas fa-search text-xs"></i>
    </div>
    <input name="search" value="<%= search %>" placeholder="Cari username, email, atau ID transaksi..." class="form-control-custom pl-10 w-full py-2.5 text-xs font-medium text-gray-700">
  </div>
  <button type="submit" class="btn-dark-custom bg-gray-900 text-white hover:bg-gray-800 px-6 py-2.5 text-xs font-medium flex items-center justify-center gap-2 whitespace-nowrap rounded-lg transition-all">
    Cari Data
  </button>
</form>

<!-- Table -->
<div class="card-custom overflow-hidden mb-8 font-medium">
  <div class="overflow-x-auto">
    <table class="w-full text-xs text-left whitespace-nowrap font-medium">
      <thead class="bg-gray-100 text-xs text-gray-900 font-medium border-b border-gray-200">
        <tr>
          <th class="px-5 py-4 font-medium">ID Transaksi</th>
          <th class="px-5 py-4 font-medium">Pengguna</th>
          <th class="px-5 py-4 font-medium">Tipe</th>
          <th class="px-5 py-4 font-medium">Jumlah</th>
          <th class="px-5 py-4 font-medium">Fee</th>
          <th class="px-5 py-4 font-medium">Status</th>
          <th class="px-5 py-4 font-medium">Batas Waktu</th>
          <th class="px-5 py-4 font-medium">Tanggal</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 font-medium">
        <% if (transactions.length === 0) { %>
          <tr>
            <td colspan="8" class="px-5 py-8 text-center font-medium text-gray-900 text-xs">Tidak ada transaksi yang ditemukan.</td>
          </tr>
        <% } else { %>
          <% transactions.forEach(t => { %>
          <tr class="hover:bg-gray-100 transition-colors">
            <td class="px-5 py-3 text-xs font-medium text-gray-700">
              <%= t.reference %>
            </td>
            <td class="px-5 py-3 text-xs">
              <div class="flex flex-col">
                <span class="text-xs font-medium text-gray-900"><%= t.userId?.username || 'Pengguna Dihapus' %></span>
                <span class="text-xs font-medium text-gray-900"><%= t.userId?.email || '-' %></span>
              </div>
            </td>
            <td class="px-5 py-3 text-xs">
              <% if (t.type === 'deposit') { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-blue-100 text-blue-700">
                  <i class="fas fa-arrow-down text-[8px]"></i> Deposit
                </span>
              <% } else if (t.type === 'withdraw') { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-orange-100 text-orange-700">
                  <i class="fas fa-arrow-up text-[8px]"></i> Withdraw
                </span>
              <% } %>
            </td>
            <td class="px-5 py-3 text-xs font-medium text-gray-900">Rp <%= t.amount.toLocaleString() %></td>
            <td class="px-5 py-3 text-xs font-medium text-gray-900">Rp <%= t.fee.toLocaleString() %></td>
            <td class="px-5 py-3 text-xs">
              <% 
                let statusClass = 'status-pending';
                let statusIcon = 'fa-clock';
                if (t.status === 'paid' || t.status === 'success') {
                  statusClass = 'status-success';
                  statusIcon = 'fa-check-circle';
                } else if (t.status === 'expired' || t.status === 'rejected') {
                  statusClass = 'status-error';
                  statusIcon = 'fa-times-circle';
                }
              %>
              <span class="status-badge font-medium <%= statusClass %>">
                <i class="fas <%= statusIcon %> text-xs"></i> <%= t.status %>
              </span>
            </td>
            <td class="px-5 py-3 text-xs font-medium text-gray-900"><%= t.expiredAt ? t.expiredAt.toLocaleString() : '-' %></td>
            <td class="px-5 py-3 text-xs font-medium text-gray-900"><%= t.createdAt.toLocaleString() %></td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>